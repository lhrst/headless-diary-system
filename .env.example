# Database
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://diary_user:${POSTGRES_PASSWORD}@postgres:5432/diary

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change_me_random_string_64_chars
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# OpenRouter API (for LLM calls)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# File storage
DIARY_STORAGE_PATH=/data/diaries
MEDIA_STORAGE_PATH=/data/media

# Media limits
MEDIA_MAX_PHOTO_MB=20
MEDIA_MAX_VIDEO_MB=500
MEDIA_MAX_AUDIO_MB=100
VIDEO_MAX_KEYFRAMES=8

# Whisper (for audio transcription)
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=auto
WHISPER_CLOUD_FALLBACK=false

# Agent
AGENT_USER_ID=00000000-0000-0000-0000-000000000001

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
